        {
          "name": "Create post",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Random title үүсгэх (Pre-request script)\r",
                  "pm.environment.set(\"randomTitle\", \"Test post \" + Math.floor(Math.random() * 10000));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201\", () => {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"New post has id\", () => {\r",
                  "    const d = pm.response.json();\r",
                  "    pm.expect(d).to.have.property(\"id\");\r",
                  "    pm.expect(d.id).to.be.a(\"number\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Title matches sent value\", () => {\r",
                  "    const d = pm.response.json();\r",
                  "    pm.expect(d).to.have.property(\"title\");\r",
                  "    pm.expect(d.title).to.be.a(\"string\");\r",
                  "});\r",
                  "\r",
                  "// Chain: post id хадгалах\r",
                  "pm.environment.set(\"postId\", pm.response.json().id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
