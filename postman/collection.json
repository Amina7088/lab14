    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time < 1s\", () => {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Content-Type is JSON\", () => {\r",
                  "    pm.response.to.have.header(\"Content-Type\");\r",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Token exists and is string\", () => {\r",
                  "    const d = pm.response.json();\r",
                  "    pm.expect(d).to.have.property(\"accessToken\"); // token → accessToken\r",
                  "    pm.expect(d.accessToken).to.be.a(\"string\");\r",
                  "});\r",
                  "\r",
                  "const json = pm.response.json();\r",
                  "pm.environment.set(\"token\", json.accessToken); // json.token → json.accessToken\r",
                  "pm.environment.set(\"userId\", json.id);\r",
                  "\r",
                  "pm.test(\"userId is a number\", () => {\r",
                  "    const d = pm.response.json();\r",
                  "    pm.expect(d.id).to.be.a(\"number\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"username\": \"emilys\",\r\n  \"password\": \"emilyspass\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
